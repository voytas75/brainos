# BrainOS project environment example
# Copy to .env for local project-scoped configuration.
# Shell env still overrides these values.
#
# Vector runtime configuration is separate from embedding-provider configuration.
# Uncomment one embedding-provider block below that matches your setup.

# sqlite-vec runtime
BRAINOS_SQLITE_VEC_PATH=/absolute/path/to/sqlite-vec/vec0.so

# --- Azure OpenAI embeddings ---
# BRAINOS_EMBEDDING_MODEL=azure/YOUR_EMBEDDING_DEPLOYMENT
# AZURE_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_KEY=YOUR_AZURE_API_KEY
# AZURE_API_VERSION=2024-10-21

# --- OpenAI embeddings ---
# BRAINOS_EMBEDDING_MODEL=openai/text-embedding-3-small
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# --- Ollama embeddings ---
# BRAINOS_EMBEDDING_MODEL=ollama/nomic-embed-text
# BRAINOS_EMBEDDING_API_BASE=http://localhost:11434

# --- OpenAI-compatible embeddings endpoint ---
# BRAINOS_EMBEDDING_MODEL=openai/YOUR_MODEL_NAME
# BRAINOS_EMBEDDING_API_BASE=https://your-endpoint/v1
# BRAINOS_EMBEDDING_API_KEY=YOUR_PROVIDER_API_KEY
# BRAINOS_EMBEDDING_API_VERSION=YOUR_API_VERSION

# Optional generic BrainOS-facing overrides
# BRAINOS_EMBEDDING_PROVIDER=
# BRAINOS_EMBEDDING_API_BASE=
# BRAINOS_EMBEDDING_API_KEY=
# BRAINOS_EMBEDDING_API_VERSION=
# BRAINOS_EMBEDDING_HEADERS_JSON=
