# BrainOS project environment example
# Copy to .env for local project-scoped configuration.
# Shell env still overrides these values.

BRAINOS_SQLITE_VEC_PATH=/absolute/path/to/sqlite-vec/vec0.so
BRAINOS_EMBEDDING_MODEL=azure/YOUR_EMBEDDING_DEPLOYMENT
AZURE_API_BASE=https://your-resource.openai.azure.com
AZURE_API_KEY=YOUR_AZURE_API_KEY
AZURE_API_VERSION=2024-10-21
